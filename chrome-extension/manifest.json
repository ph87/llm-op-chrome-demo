{
  "manifest_version": 3,
  "name": "LLM JS Runner",
  "version": "1.1.0",
  "description": "Receives commands and JS via Native Messaging bridge and executes in Chrome.",
  "permissions": ["scripting", "activeTab", "tabs", "storage", "alarms", "nativeMessaging", "debugger"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "LLM JS Runner"
  }
}
